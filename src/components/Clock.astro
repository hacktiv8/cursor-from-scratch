---
import { INDONESIA_ZONES, WORLD_ZONES } from "../scripts/clock";
---

<section class="zones" aria-label="Perbandingan waktu Indonesia">
  {
    INDONESIA_ZONES.map((zone) => (
      <article class="zone" data-zone={zone.id}>
        <h2 class="zone-label">{zone.label}</h2>
        <p class="zone-name">{zone.name}</p>
        <time class="clock" datetime="">--:--:--</time>
        <p class="date">Memuat tanggal…</p>
      </article>
    ))
  }
</section>

<section class="world" aria-label="Perbandingan waktu kota dunia">
  <h2 class="world-heading">Kota dunia</h2>
  <div class="world-zones">
    {
      WORLD_ZONES.map((zone) => (
        <article class="world-zone" data-zone={zone.id}>
          <h3 class="world-label">{zone.label}</h3>
          <p class="world-name">{zone.name}</p>
          <time class="world-clock" datetime="">--:--:--</time>
          <p class="world-date">Memuat tanggal…</p>
        </article>
      ))
    }
  </div>
</section>

<script>
  import { startIndonesiaClocks, startWorldClocks } from "../scripts/clock";

  const readZones = (rootSelector: string, clockSelector: string, dateSelector: string) =>
    Array.from(document.querySelectorAll<HTMLElement>(rootSelector)).flatMap((zoneEl) => {
      const id = zoneEl.dataset.zone;
      const clockEl = zoneEl.querySelector(clockSelector);
      const dateEl = zoneEl.querySelector(dateSelector);

      if (!id || !(clockEl instanceof HTMLTimeElement) || !(dateEl instanceof HTMLElement)) {
        return [];
      }

      return [{ id, rootEl: zoneEl, clockEl, dateEl }];
    });

  const indonesiaZones = readZones(".zone", "time.clock", ".date");
  if (indonesiaZones.length === 3) {
    startIndonesiaClocks(indonesiaZones);
  }

  const worldZones = readZones(".world-zone", "time.world-clock", ".world-date");
  if (worldZones.length === 6) {
    startWorldClocks(worldZones);
  }
</script>
